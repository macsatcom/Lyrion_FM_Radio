# FM Radio Docker — environment example
# Copy this file to .env and adjust the values, then run:
#   docker compose --env-file .env up
#
# Alternatively, set these directly under 'environment:' in docker-compose.yml.

# ── Icecast mode ─────────────────────────────────────────────────────────────
# 'internal'  — Icecast runs inside this container (default)
# 'external'  — stream to an existing Icecast server on your network
ICECAST_MODE=internal

# ── Internal mode ─────────────────────────────────────────────────────────────
# Passwords for the Icecast instance that runs inside the container.
# (Ignored when ICECAST_MODE=external)
ICECAST_SOURCE=changeme
ICECAST_ADMIN_PASS=changeme_admin

# ── External mode ─────────────────────────────────────────────────────────────
# Uncomment and fill in when ICECAST_MODE=external.
# ICECAST_MODE=external
# ICECAST_HOST=192.168.1.50    # hostname or IP of the existing Icecast server
# ICECAST_SOURCE=your-source-password

# ── Shared Icecast settings ───────────────────────────────────────────────────
ICECAST_PORT=8000
ICECAST_MOUNT=/fm

# ── RTL-SDR / Daemon ─────────────────────────────────────────────────────────
RTL_DEVICE=0              # RTL-SDR device index (0 = first dongle)
STARTUP_FREQ=90800000     # startup frequency in Hz (90.8 MHz)
DAEMON_PORT=8080
